# Copy to .env with scripts/configure.sh. Never commit the generated .env.
WEBKDE_HOST_USER=desktop-user
WEBKDE_PUID=1000
WEBKDE_PGID=1000
WEBKDE_TZ=Etc/UTC

# Bind to 127.0.0.1 and use an SSH tunnel by default. Change to 0.0.0.0 only
# on a trusted LAN or behind a hardened reverse proxy.
WEBKDE_BIND=127.0.0.1
WEBKDE_HTTPS_PORT=3001
WEBKDE_USER=webkde
WEBKDE_PASSWORD=replace-with-a-long-random-password
WEBKDE_BASIC_AUTH=true
WEBKDE_SCROLL_SCALE=0.25

WEBKDE_RUNTIME_DIR=/run/user/1000/webkde
WEBKDE_PULSE_DIR=/run/user/1000/pulse
WEBKDE_DRI_NODE=/dev/dri/renderD128
WEBKDE_CONFIG_DIR=/var/lib/webkde/config

WEBKDE_MONITOR_WIDTH=1920
WEBKDE_MONITOR_HEIGHT=1080

# This is the same family/tag used by the current LinuxServer Webtop build.
SELKIES_BASE_IMAGE=ghcr.io/linuxserver/baseimage-selkies:debiantrixie@sha256:ac7fd6d182238b4a99e66554c5e75be48a714e2a0c9da81bd18e171ff9ba3dd5
