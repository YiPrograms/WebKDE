<?xml version="1.0"?>
<labwc_config>
  <core>
    <decoration>server</decoration>
    <gap>0</gap>
  </core>

  <theme>
    <name>Clearlooks</name>
  </theme>

  <placement>
    <policy>cascade</policy>
    <cascadeOffset x="0" y="0" />
  </placement>

  <keyboard>
    <default />
    <!-- Selkies injects these private shortcuts for the browser UI control. -->
    <keybind key="C-A-F9">
      <action name="ForEach">
        <query><title>*WL-0*</title></query>
        <then><action name="UnSnap" /><action name="Maximize" /></then>
      </action>
    </keybind>
    <keybind key="C-A-F10">
      <action name="ForEach">
        <query><title>*WL-0*</title></query>
        <then><action name="UnMaximize" /><action name="SnapToEdge" direction="left" /></then>
      </action>
      <action name="ForEach">
        <query><title>*WL-1*</title></query>
        <then><action name="UnMaximize" /><action name="SnapToEdge" direction="right" /></then>
      </action>
    </keybind>
    <keybind key="C-A-F11">
      <action name="ForEach">
        <query><title>*WL-0*</title></query>
        <then><action name="UnMaximize" /><action name="SnapToEdge" direction="up" /></then>
      </action>
      <action name="ForEach">
        <query><title>*WL-1*</title></query>
        <then><action name="UnMaximize" /><action name="SnapToEdge" direction="down" /></then>
      </action>
    </keybind>
  </keyboard>

  <mouse>
    <default />
  </mouse>

  <!-- KWin's nested backend includes the output name in each window title. -->
  <windowRules>
    <windowRule title="*WL-0*" serverDecoration="no"
                skipTaskbar="yes" skipWindowSwitcher="yes">
      <action name="Maximize" />
    </windowRule>
    <windowRule title="*WL-1*" serverDecoration="no"
                skipTaskbar="yes" skipWindowSwitcher="yes" />
  </windowRules>
</labwc_config>
