<?xml version="1.0"?>
<labwc_config>
  <core>
    <decoration>server</decoration>
    <gap>0</gap>
  </core>

  <theme>
    <name>Clearlooks</name>
  </theme>

  <placement>
    <policy>cascade</policy>
    <cascadeOffset x="0" y="0" />
  </placement>

  <keyboard>
    <default />
  </keyboard>

  <mouse>
    <default />
  </mouse>

  <!--
    KWin's nested Wayland backend titles its output windows with the backend
    output name. Keep both windows alive for the entire Plasma session and
    place them on a single Pixelflux canvas. The host-side mode script enables
    or disables WL-1 through KScreen.
  -->
  <windowRules>
    <windowRule title="*WL-0*" serverDecoration="no">
      <skipTaskbar>yes</skipTaskbar>
      <skipWindowSwitcher>yes</skipWindowSwitcher>
      <fixedPosition>yes</fixedPosition>
      <action name="MoveTo" x="0" y="0" />
      <action name="ResizeTo" width="@MONITOR_WIDTH@" height="@MONITOR_HEIGHT@" />
    </windowRule>
    <windowRule title="*WL-1*" serverDecoration="no">
      <skipTaskbar>yes</skipTaskbar>
      <skipWindowSwitcher>yes</skipWindowSwitcher>
      <fixedPosition>yes</fixedPosition>
      <action name="MoveTo" x="@MONITOR_WIDTH@" y="0" />
      <action name="ResizeTo" width="@MONITOR_WIDTH@" height="@MONITOR_HEIGHT@" />
    </windowRule>
  </windowRules>
</labwc_config>
